{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Attach to Node Functions",
            "type": "node",
            "request": "attach",
            "restart": true,
            "port": 9229,
            "preLaunchTask": "func: host start",
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "http://localhost:7071",
                "uriFormat": "http://localhost:7071/api/health"
            }
        }
    ]
}